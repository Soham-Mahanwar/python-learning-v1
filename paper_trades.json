# paper_trading.py — v3.2.0  Fixed: balance tracking, P&L calculation, position averaging
import threading
from datetime import datetime

_lock            = threading.Lock()
_starting_bal    = 1_000_000.0   # ₹10 lakh
_virtual_balance = 1_000_000.0
_paper_orders    = []
_paper_positions = {}

def _now_str():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def _order_id():
    import random, string
    return "PAPER-" + "".join(random.choices(string.ascii_uppercase + string.digits, k=8))

def _detect_lot_size(symbol: str) -> int:
    s = symbol.upper()
    if s.startswith("BANKNIFTY"):  return 30
    if s.startswith("FINNIFTY"):   return 60
    if s.startswith("MIDCPNIFTY"): return 120
    if s.startswith("SENSEX"):     return 20
    if s.startswith("NIFTY"):      return 65
    return 1

def place_paper_legs(legs: list, product: str = "NRML") -> dict:
    """
    Simulate placing option legs at current LTP.
    FIX: Balance correctly debited for BUY (premium out) and
         credited for SELL (premium collected, margin blocked separately).
    """
    global _virtual_balance
    if not legs:
        return {"status": "error", "error": "No legs provided"}

    results = []
    with _lock:
        for leg in legs:
            symbol   = str(leg.get("symbol", "")).strip().upper()
            txn      = str(leg.get("transaction_type", "SELL")).strip().upper()
            quantity = int(leg.get("quantity", 0))
            ltp      = float(leg.get("ltp", 0) or 0)
            strike   = float(leg.get("strike", 0) or 0)
            expiry   = str(leg.get("expiry", "") or "")

            if not symbol:
                results.append({"symbol": symbol, "status": "error", "message": "Empty symbol",
                                 "order_id": None, "order_status": None}); continue
            if txn not in ("BUY", "SELL"):
                results.append({"symbol": symbol, "status": "error", "message": f"Bad transaction_type '{txn}'",
                                 "order_id": None, "order_status": None}); continue
            if quantity <= 0:
                results.append({"symbol": symbol, "status": "error", "message": f"Bad quantity {quantity}",
                                 "order_id": None, "order_status": None}); continue

            premium = ltp * quantity
            oid     = _order_id()

            # Update balance
            if txn == "BUY":
                _virtual_balance -= premium   # Pay premium
            else:
                _virtual_balance += premium   # Collect premium (margin blocked conceptually)

            order = {
                "order_id": oid, "symbol": symbol, "transaction_type": txn,
                "quantity": quantity, "ltp": ltp, "strike": strike, "expiry": expiry,
                "premium": round(premium, 2), "product": product,
                "timestamp": _now_str(), "status": "COMPLETE", "paper": True,
            }
            _paper_orders.append(order)

            # Update position
            key = symbol
            if key in _paper_positions:
                pos = _paper_positions[key]
                if pos["transaction_type"] == txn:
                    # Adding to position — weighted average price
                    old_qty = pos["quantity"]
                    new_qty = old_qty + quantity
                    pos["avg_price"] = round((pos["avg_price"] * old_qty + ltp * quantity) / new_qty, 2)
                    pos["quantity"]  = new_qty
                else:
                    # Reducing / closing
                    pos["quantity"] -= quantity
                    if pos["quantity"] <= 0:
                        del _paper_positions[key]
            else:
                _paper_positions[key] = {
                    "symbol": symbol, "transaction_type": txn, "quantity": quantity,
                    "avg_price": ltp, "entry_price": ltp, "strike": strike, "expiry": expiry,
                    "product": product, "open_at": _now_str(), "paper": True,
                }

            results.append({
                "symbol": symbol, "transaction_type": txn, "quantity": quantity,
                "order_id": oid, "order_status": "COMPLETE", "status": "success",
                "message": f"Paper order {oid} filled @ ₹{ltp:.2f} | Premium: ₹{premium:.2f}",
                "ltp": ltp, "strike": strike, "expiry": expiry, "paper": True,
            })

    placed  = sum(1 for r in results if r["status"] == "success")
    failed  = sum(1 for r in results if r["status"] != "success")
    overall = "success" if failed == 0 else ("error" if placed == 0 else "partial")
    return {"status": overall, "results": results, "placed": placed, "failed": failed}


def exit_paper_legs(legs: list, product: str = "NRML") -> dict:
    """Close paper positions by reversing transaction type."""
    if not legs:
        return {"status": "error", "error": "No legs provided"}
    exit_legs_list = []
    for leg in legs:
        orig = (leg.get("transaction_type") or leg.get("original_transaction_type") or "SELL").strip().upper()
        exit_legs_list.append({
            "symbol":           str(leg.get("symbol", "")).strip().upper(),
            "transaction_type": "BUY" if orig == "SELL" else "SELL",
            "quantity":         int(leg.get("quantity", 0)),
            "ltp":              float(leg.get("ltp", 0) or 0),
            "strike":           float(leg.get("strike", 0) or 0),
            "expiry":           str(leg.get("expiry", "") or ""),
        })
    return place_paper_legs(exit_legs_list, product)


def get_paper_positions() -> dict:
    with _lock:
        positions = [p for p in _paper_positions.values() if p.get("quantity", 0) > 0]
    return {"status": "success", "positions": positions, "count": len(positions)}


def get_paper_orders() -> dict:
    with _lock:
        orders = list(reversed(_paper_orders))
    return {"status": "success", "orders": orders, "count": len(orders)}


def get_paper_summary() -> dict:
    """FIX: Now correctly computes unrealised P&L from positions."""
    with _lock:
        positions = [p for p in _paper_positions.values() if p.get("quantity", 0) > 0]
        orders    = list(_paper_orders)
        balance   = _virtual_balance
        start     = _starting_bal

    # Compute total P&L from closed orders
    realised_pnl = balance - start

    return {
        "status":          "success",
        "open_positions":  len(positions),
        "total_orders":    len(orders),
        "virtual_balance": round(balance, 2),
        "starting_balance":round(start, 2),
        "realised_pnl":    round(realised_pnl, 2),
        "positions":       positions,
    }


def reset_paper_trading() -> dict:
    global _paper_orders, _paper_positions, _virtual_balance
    with _lock:
        _paper_orders    = []
        _paper_positions = {}
        _virtual_balance = _starting_bal
    return {"status": "success", "message": "Paper trading reset. Balance restored to ₹10,00,000"}